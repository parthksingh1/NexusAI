// NexusAI — unified Postgres schema (Prisma).
// pgvector columns declared with Unsupported("vector(N)") — we read/write them via raw SQL
// because Prisma doesn't natively support vector yet.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "fullTextSearch", "multiSchema"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector"), pgcrypto, pg_trgm, uuidOssp(map: "uuid-ossp")]
  schemas    = ["public", "nexus", "rag"]
}

// ─── Users & Orgs ──────────────────────────────────────────────
model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String?
  avatarUrl     String?
  passwordHash  String?
  tier          SubscriptionTier @default(FREE)
  stripeCustomerId String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  agents        Agent[]
  documents     Document[]
  apiKeys       ApiKey[]
  memberships   OrgMembership[]

  @@schema("nexus")
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  members   OrgMembership[]

  @@schema("nexus")
}

model OrgMembership {
  id     String @id @default(uuid())
  userId String
  orgId  String
  role   OrgRole @default(MEMBER)
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@schema("nexus")
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER

  @@schema("nexus")
}

enum SubscriptionTier {
  FREE
  PRO
  TEAM
  ENTERPRISE

  @@schema("nexus")
}

model ApiKey {
  id         String   @id @default(uuid())
  userId     String
  name       String
  prefix     String   // first 8 chars, searchable
  hash       String   // argon2 of full key
  scopes     String[] @default([])
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([prefix])
  @@schema("nexus")
}

// ─── Agents ────────────────────────────────────────────────────
model Agent {
  id                 String   @id @default(uuid())
  ownerId            String
  name               String
  goal               String
  persona            Json     // AgentPersona
  tools              String[] @default([])      // tool names enabled
  modelRoutingPolicy Json     @default("{}")    // ModelRoutingPolicy
  status             AgentStatus @default(IDLE)
  publishedToMarketplace Boolean @default(false)
  forkFrom           String?                     // parent agent id
  stars              Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  owner   User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  runs    AgentRun[]
  memories AgentMemory[]

  @@index([ownerId])
  @@index([publishedToMarketplace])
  @@schema("nexus")
}

enum AgentStatus {
  IDLE
  RUNNING
  PAUSED
  STOPPED
  ERROR

  @@schema("nexus")
}

// ─── Runs & Steps ──────────────────────────────────────────────
model AgentRun {
  id            String   @id @default(uuid())
  agentId       String
  input         String
  status        RunStatus @default(QUEUED)
  startedAt     DateTime @default(now())
  finishedAt    DateTime?
  totalTokens   Int      @default(0)
  totalCostUsd  Decimal  @default(0) @db.Decimal(12, 6)
  result        String?
  errorMessage  String?

  agent   Agent       @relation(fields: [agentId], references: [id], onDelete: Cascade)
  steps   AgentStep[]

  @@index([agentId, startedAt(sort: Desc)])
  @@index([status])
  @@schema("nexus")
}

enum RunStatus {
  QUEUED
  RUNNING
  WAITING_HUMAN
  SUCCEEDED
  FAILED
  CANCELLED

  @@schema("nexus")
}

model AgentStep {
  id          String   @id @default(uuid())
  runId       String
  step        Int
  kind        StepKind
  content     String
  tool        String?
  toolInput   Json?
  toolOutput  Json?
  latencyMs   Int?
  tokensIn    Int?
  tokensOut   Int?
  costUsd     Decimal? @db.Decimal(12, 6)
  model       String?
  createdAt   DateTime @default(now())

  run   AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, step])
  @@index([runId])
  @@schema("nexus")
}

enum StepKind {
  THOUGHT
  ACTION
  OBSERVATION
  FINAL

  @@schema("nexus")
}

// ─── Memory (Postgres tier; Neo4j is the graph tier) ───────────
model AgentMemory {
  id         String      @id @default(uuid())
  agentId    String
  type       MemoryType
  content    String
  importance Float       @default(0.5)
  embedding  Unsupported("vector(768)")?
  createdAt  DateTime    @default(now())
  accessedAt DateTime?

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, type])
  @@schema("nexus")
}

enum MemoryType {
  EPISODIC
  SEMANTIC
  PROCEDURAL
  REFLECTION

  @@schema("nexus")
}

// ─── RAG ───────────────────────────────────────────────────────
model Document {
  id        String @id @default(uuid())
  ownerId   String
  source    DocumentSource
  sourceId  String
  title     String
  url       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner  User    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  chunks Chunk[]

  @@unique([ownerId, source, sourceId])
  @@index([ownerId])
  @@schema("rag")
}

enum DocumentSource {
  NOTION
  GITHUB
  SLACK
  URL
  UPLOAD

  @@schema("rag")
}

model Chunk {
  id          String @id @default(uuid())
  documentId  String
  text        String
  tokenCount  Int
  position    Int
  metadata    Json?
  embedding   Unsupported("vector(768)")?
  tsv         Unsupported("tsvector")?         // for BM25-ish sparse search

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@schema("rag")
}

// ─── Marketplace ───────────────────────────────────────────────
model AgentStar {
  id      String @id @default(uuid())
  agentId String
  userId  String
  createdAt DateTime @default(now())

  @@unique([agentId, userId])
  @@schema("nexus")
}

// ─── Safety / Approvals ────────────────────────────────────────
model ApprovalRequest {
  id         String   @id @default(uuid())
  runId      String
  stepId     String?
  tool       String
  input      Json
  riskLevel  String
  status     ApprovalStatus @default(PENDING)
  decidedBy  String?
  decidedAt  DateTime?
  createdAt  DateTime @default(now())

  @@index([runId])
  @@index([status])
  @@schema("nexus")
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED

  @@schema("nexus")
}

// ─── Autonomous workflows ──────────────────────────────────────
model CronJob {
  id        String   @id @default(uuid())
  agentId   String
  schedule  String
  input     String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([agentId])
  @@schema("nexus")
}
