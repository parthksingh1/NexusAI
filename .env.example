# ─── LLM Providers ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx
GOOGLE_API_KEY=xxxxx

# ─── Databases ─────────────────────────────────────────────────
DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexusai?schema=public
REDIS_URL=redis://localhost:6379
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=nexuspass
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ─── Kafka ─────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=nexusai

# ─── Services ──────────────────────────────────────────────────
ORCHESTRATOR_PORT=4000
ORCHESTRATOR_URL=http://localhost:4000
RAG_PORT=5000
RAG_URL=http://localhost:5000
WEB_PORT=3000

# ─── Auth ──────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-please
NEXTAUTH_SECRET=change-me-too
NEXTAUTH_URL=http://localhost:3000

# ─── Observability ─────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
LOG_LEVEL=info
