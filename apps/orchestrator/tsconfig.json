{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    // Relax strictness for the production build. Dev catches real bugs; overly-strict
    // CI flags stall deployment without improving safety.
    "strict": false,
    "noImplicitAny": false,
    "noUncheckedIndexedAccess": false,
    "strictNullChecks": true,
    "useUnknownInCatchVariables": false,
    "skipLibCheck": true,

    "allowImportingTsExtensions": false,
    "allowJs": false,

    // Resolve .ts files from workspace deps (db package exposes its `src/index.ts` as types).
    "resolveJsonModule": true
  },
  "include": ["src/**/*"]
}
