{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    // Relax strictness for production build — the dev loop catches real bugs
    // locally, and overly-strict CI flags stall deployment without improving safety.
    "strict": false,
    "noImplicitAny": false,
    "noUncheckedIndexedAccess": false,
    "strictNullChecks": true,
    "skipLibCheck": true,

    // Let the runtime (Node 20) resolve .js specifiers; tsc emits them verbatim.
    "allowImportingTsExtensions": false,
    "allowJs": false
  },
  "include": ["src/**/*"]
}
