{
  "name": "@nexusai/cli",
  "version": "0.1.0",
  "description": "Official NexusAI command-line interface",
  "type": "module",
  "bin": { "nexus": "./dist/bin.js" },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/bin.js 2>/dev/null || true",
    "dev": "tsx src/bin.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@nexusai/sdk": "workspace:*",
    "commander": "^12.1.0",
    "chalk": "^5.3.0",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "@types/node": "^22.7.4"
  }
}
